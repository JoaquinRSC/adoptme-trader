{
  "name": "adoptme-trader",
  "version": "0.5.0",
  "description": "Trade manager for Roblox Adopt Me: inventory, two-source value comparison (AMVGG + Elvebredd), demand-adjusted fairness scoring, and market browsing. Quasar + Vue 3 SSR.",
  "productName": "AdoptMe Trader",
  "author": "JoaquinRSC (https://github.com/JoaquinRSC)",
  "license": "MIT",
  "homepage": "https://dawn-thunder-3296.fly.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/JoaquinRSC/adoptme-trader"
  },
  "private": true,
  "scripts": {
    "dev": "quasar dev -m ssr",
    "build": "quasar build -m ssr && node -e \"try{require('fs').renameSync('dist/ssr/server/server-entry.mjs','dist/ssr/server/server-entry.js')}catch(e){}\"",
    "start": "node dist/ssr/index.js",
    "fetch-values": "node scripts/fetch-values.mjs",
    "lint": "eslint --ext .js,.ts,.vue src src-ssr"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.12",
    "@types/compression": "^1.8.1",
    "compression": "^1.8.1",
    "express": "^4.18.2",
    "pinia": "^2.1.7",
    "quasar": "^2.16.0",
    "vue": "^3.4.18",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@quasar/app-vite": "^2.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  },
  "engines": {
    "node": ">=22"
  }
}
